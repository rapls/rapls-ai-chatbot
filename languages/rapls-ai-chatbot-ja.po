msgstr "reCAPTCHA 設定"

#: templates/admin/settings.php:1204
msgid "Enabled — site key and secret key configured."
msgstr "有効 — サイトキーとシークレットキーが設定済みです。"

#: templates/admin/settings.php:1206
msgid ""
